# Resend for magic link emails — sign up at resend.com, EU sending region
RESEND_API_KEY="re_xxx"
RESEND_FROM_EMAIL="hello@ankommen.de"

# App config
NEXT_PUBLIC_APP_URL="http://localhost:3000"
