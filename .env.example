# Database — get from Neon (https://neon.tech), pick Frankfurt region
DATABASE_URL="postgresql://user:password@host.neon.tech/ankommen?sslmode=require"

# Auth.js (generate with: openssl rand -base64 32)
AUTH_SECRET="replace-me-with-a-real-secret"
